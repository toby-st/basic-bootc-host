{
    "default": [
        {
            "type": "insecureAcceptAnything"
        }
    ],
    "transports": {
        "docker": {
            "ghcr.io/toby-st/basic-bootc-host": [
                {
                    "type": "sigstoreSigned",
                    "keyPaths": ["/usr/local/etc/2025.11.pub"],
                    "signedIdentity": {
                        "type": "matchRepository"
                    }
                }
            ]
        }
    }
}
